# SignalRoot - Local Development
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgres://signalroot:signalroot@localhost:5432/signalroot?sslmode=disable
DATABASE_MAX_CONNECTIONS=25

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:19092
KAFKA_TOPIC_SIGNALS=signalroot.signals
KAFKA_TOPIC_JOBS=signalroot.jobs
KAFKA_CONSUMER_GROUP=signalroot-worker

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=incident_dna

# Anthropic (optional for dev — stubs are used when empty)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-32chars!
SESSION_SECRET=dev-session-secret-change-in-prod-32!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Encryption
ENCRYPTION_KEY=dev-encryption-key-must-be-32byte!

# ML Service
ML_SERVICE_URL=http://localhost:8082

# Feature Flags
FEATURE_SIMILARITY_ENABLED=true
FEATURE_AUTO_CORRELATION=true
FEATURE_COMPLIANCE_REPORTS=true

# Limits
FREE_TIER_INCIDENTS_PER_MONTH=50
FREE_TIER_LLM_CALLS_PER_MONTH=100
INGESTION_RATE_LIMIT_PER_MINUTE=1000

# Frontend
FRONTEND_URL=http://localhost:3000
